# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VRoid Hub OAuth Credentials
# You can find these in the application settings on hub.vroid.com
VROID_CLIENT_ID=""
VROID_CLIENT_SECRET=""

# reCAPTCHA v3
VITE_RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""

# Secure Motherboard Zero-Latency Bidirectional WSS Tether Secret Code
MOTHERBOARD_SECRET="secure-motherboard-token-2026"

# Optional Cloud Motherboard URL to establish a secure client connection for real-time 3D telemetry
CLOUD_MOTHERBOARD_URL=""
